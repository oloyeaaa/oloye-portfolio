# Copy to .env.local for local dev. Also set these in Vercel Project Settings > Environment Variables.

# Airtable Personal Access Token (PAT).
# Create at https://airtable.com/create/tokens with data.records:read scope on the Brain base.
AIRTABLE_API_KEY=

# Airtable base + Blog table IDs (defaults are the AI Team Brain base).
# Override only if you use a different base/table.
AIRTABLE_BASE_ID=appSD2mpRbokvWzU6
AIRTABLE_BLOG_TABLE_ID=tbl6kEFqw0P1rT7Gv

# Optional: override the canonical site URL (defaults to https://www.oloye.co.uk).
NEXT_PUBLIC_SITE_URL=
